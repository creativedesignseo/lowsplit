# ============================================================
# LowSplit — Variables de entorno
# Copia este archivo a `.env.local` para desarrollo local.
# En Netlify, configura estas variables en Site settings → Environment variables.
# ============================================================

# ----- Supabase (PÚBLICAS — se embeben en el bundle frontend) -----
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ----- Supabase (SECRETA — solo backend, NO frontend) -----
# Service role key. Saltea RLS, máximo privilegio. No usar en código frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ----- Stripe (PÚBLICA) -----
# Publishable key. Empieza por pk_test_ en test, pk_live_ en producción.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ----- Stripe (SECRETAS — solo backend) -----
# Secret key. Empieza por sk_test_ en test, sk_live_ en producción.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret.
# Obtener de: Stripe Dashboard → Developers → Webhooks → tu endpoint → Signing secret.
# Endpoint a registrar en Stripe: https://lowsplit.com/.netlify/functions/stripe-webhook
# Eventos a escuchar (mínimo): checkout.session.completed, payment_intent.payment_failed,
# charge.refunded, charge.dispute.created
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- App -----
# URL de producción. Se usa para construir success_url / cancel_url de Stripe Checkout
# y como fallback cuando event.headers.origin no esté disponible.
APP_PROD_URL=https://lowsplit.com

# URL del frontend en desarrollo local.
VITE_APP_URL=http://localhost:5173
